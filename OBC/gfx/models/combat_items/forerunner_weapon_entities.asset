# MUZZLE FLASHES

entity = {
	name = "sentinel_beam_large_muzzle_entity"
	pdxmesh = "locator_mesh"
	
	default_state = "idle"
	state = { name = "idle" state_time = 0.5 looping = no
		event = { time = 0 particle = "sentinel_beam_large_muzzle_particle" keep_particle = yes sound = { soundeffect = sentinel_beam } }
		event = { trigger_once = yes sound = { soundeffect = "sentinel_beam" } }
	}
}

