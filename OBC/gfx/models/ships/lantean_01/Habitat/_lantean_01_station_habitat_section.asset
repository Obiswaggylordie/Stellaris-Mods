entity = {
	name = "lantean_01_habitat_phase_03_entity"
	locator = { name = part1 }
	
	scale = 1.0
	
	default_state = "habitat_idle"
	state = { name = "habitat_idle" state_time = 5 }
	state = { name = "construction" state_time = 5 }
	
