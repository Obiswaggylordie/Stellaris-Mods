
########## WEAPONS SFX ############

############ CLOSE WEAPONS SFX
#SENTINEL BEAM 
soundeffect = {
	name = sentinel_beam
	falloff = "falloff_weapons_close"
	sounds = {
		sound = sentinel_beam
	}
	is3d = yes
	max_audible = 4
	max_audible_behaviour = fail
	delay_random_offset = { 0.0 0.5 }
	volume_random_offset = { 0.0 0.15 }
	volume = 0.8
	fade_out = 0.2
}
soundeffect = {
	name = sentinel_beam_hit
	falloff = "falloff_weapons_close"
	sounds = {
		sound = sentinel_beam_hit
	} 
	is3d = yes
	max_audible = 2
	max_audible_behaviour = fail
	delay_random_offset = { 0.0 0.5 }
	volume_random_offset = { 0.0 0.15 }
	volume = 0.1
	fade_out = 0.2
}

soundeffect = {
	name = distance_sentinel_beam
	falloff = "falloff_weapons_distance"
	sounds = {
		sound = sentinel_beam
	}
	is3d = yes
	max_audible = 2
	max_audible_behaviour = fail
	playbackrate_random_offset = { 0.0 -2.05 }
	volume = 0.2
	fade_out = 0.2
}
soundeffect = {
	name = distance_sentinel_beam_hit
	falloff = "falloff_weapons_distance"
	sounds = {
		sound = sentinel_beam_hit
	}
	is3d = yes
	max_audible = 1
	max_audible_behaviour = fail
	playbackrate_random_offset = { 0.0 -2.05 }
	volume = 0.15
	fade_out = 0.2
}

