#################
# Ancient Drones
#################

soundeffect = {
	name = ancient_drone_fire
	falloff = "falloff_weapons_close"
	sounds = {
		sound = ancient_drone_fire
	}
	is3d = yes
	max_audible = 2
	max_audible_behaviour = fail
	fade_out = 0.2
	delay_random_offset = { 0.0 0.5 }
	volume = 0.5
}

soundeffect = {
	name = distance_ancient_drone_fire
	falloff = "falloff_weapons_distance"
	sounds = {
		sound = ancient_drone_fire
	}
	is3d = yes
	max_audible = 2
	max_audible_behaviour = fail
	playbackrate_random_offset = { 0.0 -2.05 }
	volume = 0.15
}


