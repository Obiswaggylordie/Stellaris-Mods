### Ancient Drone Muzzle Flash ###
entity = {
	name = "ancient_drones_muzzle_flash_entity"
	cull_radius = 0.05
	
	default_state = "idle"
	state = { name = "idle" state_time = 7 looping = no
		event = { time = 0 particle = "ancient_drones_muzzle_flash_particle" keep_particle = yes sound = { soundeffect = "ancient_drone_fire" } }
		event = { trigger_once = yes sound = { soundeffect = "distance_ancient_drone_fire" } }
		
	}
}

### Ancient Drone Hit Effect ###
entity = {
	name = "ancient_drones_hit_entity"
	cull_radius = 1.0
	
	state = { name = "explode_med_hp" state_time = 0.8 looping = no
		event = { time = 0.0 node = "root" particle = "ancient_drones_hit_effect_particle" sound = { soundeffect = ancient_drone_hit } }
		event = { trigger_once = yes sound = { soundeffect = "distance_ancient_drone_hit" } }
	}
	default_state = "explode_med_hp"
}

### Ancient Drone Shield Hit Effect ###
entity = {
	name = "ancient_drones_shield_hit_entity"
	cull_radius = 1.0
	
	state = { name = "explode_med_hp" state_time = 0.8 looping = no
		event = { time = 0.0 node = "root" particle = "ancient_drones_hit_effect_particle" sound = { soundeffect = ancient_drone_hit } }
		event = { trigger_once = yes sound = { soundeffect = "distance_ancient_drone_hit" } } 
	}
	default_state = "explode_med_hp"
}